# Plantilla de configuración. Copia a .env y rellena los valores reales.
# El fichero .env está en .gitignore: NO commitearlo nunca.
#
# Permisos recomendados:  chmod 640 .env  &&  chown user:group .env

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=name_db
DB_USER=name_user
# PGPASSWORD es la variable estándar de libpq. psycopg2 y psql la leen
# automáticamente del entorno; no se almacena en el dataclass de config.
PGPASSWORD=__REEMPLAZAR__

# ─────────────────────────────────────────────────────────────
# Rutas del proyecto
# ─────────────────────────────────────────────────────────────
DATASET_PATH=./                                         #path al dataset del proyecto
DICTIONARIES_PATH=data/dictionaries                     #path a los diccionarios del proyecto
LOG_DIR=./logs                                          #path a los logs del ingest

# ─────────────────────────────────────────────────────────────
# HIBP (consulta k-anonymity)
# ─────────────────────────────────────────────────────────────
HIBP_API_URL=https://api.pwnedpasswords.com/range       #API de HIBP 
HIBP_USER_AGENT=passeval-tfg/0.1
HIBP_TIMEOUT=10.0
HIBP_ADD_PADDING=true

# ─────────────────────────────────────────────────────────────
# ETL
# ─────────────────────────────────────────────────────────────
ETL_BATCH_SIZE=1000000
ETL_WORKERS=4

# ─────────────────────────────────────────────────────────────
# Sampling estratificado (analysis/sample_dataset.py)
# Independientes del ETL. SAMPLE_CHECKPOINT_LINES debe ser alto
# (cada checkpoint reescribe el TSV completo).
# ─────────────────────────────────────────────────────────────
SAMPLE_CHECKPOINT_LINES=50000000
SAMPLE_LOG_EVERY_LINES=10000000

# ─────────────────────────────────────────────────────────────
# CLI opt-in stats
# ─────────────────────────────────────────────────────────────
COLLECT_USER_STATS=true
USER_QUERIES_DATASET=user_queries

# ─────────────────────────────────────────────────────────────
# Web UI
# ─────────────────────────────────────────────────────────────
WEB_DEBUG=false   # true → muestra tokens bruteforce en claro (solo para depuración)

# ─────────────────────────────────────────────────────────────
# Operación
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
